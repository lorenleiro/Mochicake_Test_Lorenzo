    <ui:Button parse-escape-sequences="true" display-tooltip-when-elided="true" name="settings_button" class="settings-button" />
    <ui:VisualElement style="position: absolute; right: 1%; bottom: 10%; width: 150px; color: rgb(255, 255, 255); font-size: 30px;">
