                    <ui:Button parse-escape-sequences="true" display-tooltip-when-elided="true" name="change_skin_button" text="Change Skin" class="main-menu-button" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; font-size: 30px; width: 40%;" />
                </ui:VisualElement>
