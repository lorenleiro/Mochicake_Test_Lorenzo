    <ui:VisualElement style="position: absolute; width: 80%; align-self: center; top: 20%; height: 80px; border-top-left-radius: 20px; border-top-right-radius: 20px; border-bottom-right-radius: 20px; border-bottom-left-radius: 20px; background-color: rgb(0, 64, 82); border-top-width: 6px; border-right-width: 6px; border-bottom-width: 6px; border-left-width: 6px; border-left-color: rgb(0, 36, 59); border-right-color: rgb(0, 36, 59); border-top-color: rgb(0, 36, 59); border-bottom-color: rgb(0, 36, 59);">
